{
  "name": "@melazzo/vehicles",
  "version": "0.1.0",
  "description": "Base package compartilhada pelas plataformas de revenda de veículos da Melazzo Consultoria (Car With, Duo Motors, Tayco Motors).",
  "license": "UNLICENSED",
  "private": false,
  "author": "Melazzo Consultoria <vinicius.melazzo@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/melazzo/vehicles.git"
  },
  "homepage": "https://github.com/melazzo/vehicles#readme",
  "bugs": {
    "url": "https://github.com/melazzo/vehicles/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js",
      "require": "./dist/tailwind-preset.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.10",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
